@startuml
skinparam classAttributeIconSize 0

' ===== MEDIA =====
class media_work <<table>> {
    id: UUID <<PK>>
    title: TEXT
    description: TEXT
    original_release_date: DATE
}

class content <<table>> {
    id: UUID <<PK>>
    media_work_id: UUID <<FK>>
    title: TEXT (nullable)
    description: TEXT (nullable)
}

class playable_content <<table>> {
    content_id: UUID <<PK>> <<FK>>
    runtime_minutes: INT
    cut_type: TEXT (nullable)
}

content <-- playable_content

class audio_track <<table>> {
    playable_content_id: UUID <<PK>> <<FK>>
    language: TEXT <<PK>>
    format: TEXT <<PK>>
}

playable_content "1" <--> "0..*" audio_track

class media_copy <<table>> {
    id: UUID <<PK>>
    edition_id: UUID <<FK>>
    location_name: TEXT
    date_added: DATE (nullable)
    created_at: TIMESTAMP
}

class note <<table>> {
    id: UUID <<PK>>
    media_copy_id: UUID <<FK>>
    text: TEXT
    created_at: TIMESTAMP
}

media_copy "1" <-- "0.." note

' ===== MOVIE =====
class movie <<table>> {
    media_work_id: UUID <<PK>> <<FK>>
}

movie "1" --> "1" media_work

' ===== TV =====
class tv <<table>> {
    media_work_id: UUID <<PK>> <<FK>>
    status: TEXT
    ended_on: TEXT
}

tv "1" --> "1" media_work

class season <<table>> {
    id: UUID <<PK>>
    tv_id: UUID <<FK>>
    season_number: INT
    title: TEXT (nullable)
    description: TEXT (nullable)
    --
    UNIQUE(tv_id, season_number)
}

tv "1" <-- "0..*" season

class episode <<table>> {
    id: UUID <<PK>>
    season_id: UUID <<FK>>
    content_id: UUID <<FK>>
    episode_number: INT (nullable))
    air_date: DATE
    role: TEXT (nullable)
    --
    UNIQUE(season_id, episode_number)
}

season "1" <-- "0..*" episode

' ===== EDITION =====
class edition <<table>> {
    id: UUID <<PK>>
    title: TEXT
    release_date: DATE
    packaging: TEXT (nullable))
}

edition "1" <-- "0..*" media_copy

class edition_content <<table>> {
    edition_id: UUID <<PK>> <<FK>>
    content_id: UUID <<PK>> <<FK>>
    content_role: TEXT
}

edition "1" <-- "0..*" edition_content

' ===== COLLECTION GROUP =====
class collection_group <<table>> {
    id: UUID <<PK>>
    title: TEXT
}

class collection_group_membership <<table>> {
    id: UUID <<PK>>
    collection_group_id: UUID <<FK>>
    media_work_id: UUID <<FK>>
    sort_index: INT
    --
    UNIQUE(collection_group_id, media_work_id)
    UNIQUE(collection_group_id, sort_index)
}

media_work "1" <-- "0..*" collection_group_membership
collection_group "1" <-- "0..*" collection_group_membership

' ===== CONTRIBUTORS =====
class contributor <<table>> {
    id: UUID <<PK>>
    name: TEXT
}

class contribution <<table>> {
    id: UUID <<PK>>
    media_work_id: UUID <<FK>>
    contributor_id: UUID <<FK>>
    role: TEXT
    --
    UNIQUE(media_work_id, contributor_id, role)
}

media_work "1" <-- "0..*" contribution
contributor "1" <-- "0..*" contribution

@enduml
