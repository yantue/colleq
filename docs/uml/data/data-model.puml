@startuml
skinparam classAttributeIconSize 0

' ===== MEDIA =====
class media_work <<table>> {
    id: UUID <<PK>>
    type: TEXT
    title: TEXT
    original_release_date: DATE
    end_date: DATE (nullable, TV only)
}

class edition <<table>> {
    id: UUID <<PK>>
    media_work_id: UUID <<FK>>
    release_date: DATE
}

edition "0..*" --> "1" media_work

class extra <<table>> {
    edition_id: UUID <<PK>> <<FK>>
    title: TEXT <<PK>>
    type: TEXT <<PK>>
}

extra "0..*" --> "1" edition

class media_copy <<table>> {
    id: UUID <<PK>>
    edition_id: UUID <<FK>>
    location_name: TEXT
    notes: TEXT
    date_added: DATE (nullable)
    created_at: TIMESTAMP
}

media_copy "0..*" --> "1" edition

class note <<table>> {
    id: UUID <<PK>>
    media_copy_id: UUID <<FK>>
    text: TEXT
    created_at: TIMESTAMP
}

note "0..*" --> "1" media_copy

' ===== MOVIE =====
class movie_edition <<table>> {
    edition_id: UUID <<PK>> <<FK>>
    runtime_minutes: INT
    medium: TEXT (VideoMedium)
    case: TEXT (VideoCase)
    disc_count: INT
}

movie_edition "0..1" --> "1" edition

' ===== TV =====
class tv_edition <<table>> {
    edition_id: UUID <<PK>> <<FK>>
    medium: TEXT (VideoMedium)
    case: TEXT (VideoCase)
    disc_count: INT
}

tv_edition "0..1" --> "1" edition

class season <<table>> {
    id: UUID <<PK>>
    media_work_id: UUID <<FK>>
    season_number: INT
    original_release_date: DATE
    title: TEXT (nullable)
    --
    UNIQUE(media_work_id, season_number)
}

season "0..*" --> "1" media_work

class episode <<table>> {
    id: UUID <<PK>>
    season_id: UUID <<FK>>
    episode_number: INT
    air_date: DATE
    runtime_minutes: INT
    title: TEXT (nullable)
    UNIQUE(season_id, episode_number)
}

episode "0..*" --> "1" season

class tv_edition_season <<table>> {
    tv_edition_id: UUID <<PK>> <<FK>>
    season_id: UUID <<PK>> <<FK>>
}

tv_edition_season "1..*" --> "1" tv_edition
tv_edition_season "0..*" --> "1" season

' ===== MOVIE/TV =====

class audio_track <<table>> {
    edition_id: UUID <<PK>> <<FK>>
    language: TEXT <<PK>>
    format: TEXT <<PK>>
}

audio_track "0..*" --> "1" edition

' ===== COLLECTION GROUP =====
class collection_group <<table>> {
    id: UUID <<PK>>
    title: TEXT
}

class collection_group_membership <<table>> {
    id: UUID <<PK>>
    collection_group_id: UUID <<FK>>
    media_work_id: UUID <<FK>>
    sort_index: INT
    --
    UNIQUE(collection_group_id, media_work_id)
    UNIQUE(collection_group_id, sort_index)
}

collection_group_membership "0..*" --> "1" collection_group
collection_group_membership "0..*" --> "1" media_work

' ===== CONTRIBUTORS =====
class contributor <<table>> {
    id: UUID <<PK>>
    name: TEXT
}

class contribution <<table>> {
    id: UUID <<PK>>
    media_work_id: UUID <<FK>>
    contributor_id: UUID <<FK>>
    role: TEXT
    --
    UNIQUE(media_work_id, contributor_id, role)
}

contribution "0..*" --> "1" contributor
contribution "0..*" --> "1" media_work

@enduml
