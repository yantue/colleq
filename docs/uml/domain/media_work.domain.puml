@startuml
skinparam classAttributeIconSize 0

' ===== CORE =====
class MediaWork <<AggregateRoot>> {
    +Id: UUID
    +Title: string
    +Description?: string
    +OriginalReleaseDate: LocalDate
    +OriginalLanguage: Language
    +CountryOfOrigin: Country
    #creatorRoles: List<string>
    -_contributions: List<Contribution>
    -_content: List<Content>
    --
    +AddContribution(id, role): void
    +RemoveContribution(id): void
    +AddContent(content): void
    +RemoveContent(id): void
    +IsCreatorRole(role): bool
}

note top of MediaWork
Invariant:
- Must have at least one creator contribution
- Cannot remove last creator
- All Features / Episodes must reference a
  Content that is a PlayableContent inside
  MediaWork._contents
end note

class Country <<ValueObject>> {
    Code: string
}

' ===== CONTRIBUTIONS =====
class Contribution <<Entity>> {
    +Id: UUID
    +ContributorId: UUID
    +ContributorRole: ContributorRole
}

class ContributorRole <<ValueObject>> {
    +Name: string
}

MediaWork "1" *-- "1..*" Contribution

' ===== CONTENT =====
class Content <<Entity>> {
    +Id: UUID
    +Title?: string
    +Description?: string
}

MediaWork "1" *-- "0..*" Content

class PlayableContent {
    +RuntimeMinutes: int
    +CutType?: CutType
}

enum CutType {
    DirectorCut
    Extended
    FinalCut
    HomeRelease
    International
    Original
    Other
    Theatrical
    Uncut
}

Content <|-- PlayableContent

class AudioTrack <<ValueObject>> {
    +Language: Language
    +Format: AudioFormat
}

enum AudioFormat {
    AAC
    DTS
    DolbyDigital
    DolbyAtmos
}

class Language <<ValueObject>> {
    +Code: string
}

PlayableContent "1" *-- "0..*" AudioTrack

class SubtitleTrack <<ValueObject>> {
    +Language: Language
    +Region?: Region
    +Type: SubtitleType
}

enum SubtitleType {
    Standard
    SDH
    CC
}

class Region <<ValueObject>> {
    +Code: string
}

PlayableContent "1" *-- "0..*" SubtitleTrack

' ===== MOVIE =====
class Movie {
    -_features: List<UUID>
    --
    +AddFeature(id): void
    +RemoveFeature(id): void
}

MediaWork <|-- Movie
Movie ..> PlayableContent

' ===== TV =====
class TV {
    +Status: TVStatus
    +EndedOn?: LocalDate
    -_seasons: List<UUID>
    --
    +AddSeason(id): void
    +RemoveSeason(id): void
    +AddEpisodeToSeason(seasonId, episodeId, number?, airDate, role?)
    +RemoveEpisodeFromSeason(seasonId, episodeId)
}

MediaWork <|-- TV

enum TVStatus {
    Ongoing
    Ended
    Cancelled
    Unknown
}

class Season <<Entity>> {
    +Id: UUID
    +SeasonNumber: int
    +Title: string?
    +Description: string?
    _episodes: List<Episode>
    --
    +AddEpisode(id, number, airDate, role)
    +RemoveEpisode(id)
}

TV "1" *-- "1..*" Season

class Episode <<Entity>> {
    +contentId: UUID
    +EpisodeNumber?: int
    +AirDate: LocalDate
    +EpisodeRole?: EpisodeRole
}

Season "1" *-- "1..*" Episode
Episode ..> PlayableContent

enum EpisodeRole {
    Regular
    Bonus
    Special
}

' ===== CROSS-AGGREGATE REFERENCE =====
Contribution ..> Contributor

@enduml
