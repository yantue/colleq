@startuml
skinparam classAttributeIconSize 0

' ===== CORE =====
class MediaWork <<AggregateRoot>> {
    +Id: UUID
    +Title: string
    +Description?: string
    +OriginalReleaseDate: LocalDate
    -_structure: MediaStructure
    -_contributions: List<Contribution>
    -_content: List<Content>
    --
    +AddContribution(id, role): void
    +RemoveContribution(id): void
    +AddContent(content): void
    +RemoveContent(id): void
}

note top of MediaWork
Invariant:
- Must have exactly one MediaStructure
- Structure defines the MediaWork type
- Must have at least one creator contribution
- Cannot remove last creator
- Cannot remove Edition if MediaCopy exists
  referencing it (cross-aggregate)
- All Features / Episodes must reference a
  Content that is a PlayableContent inside
  MediaWork._contents
end note

abstract class MediaStructure <<Entity>> {
    --
    +Type(): MediaWorkType
    +IsCreatorRole(role): bool
}

MediaWork "1" *-- "1" MediaStructure

enum MediaWorkType {
    Movie
    TV
}

' ===== CONTRIBUTIONS =====
class Contribution <<Entity>> {
    +Id: UUID
    +ContributorId: UUID
    +Role: ContributorRole
}

class ContributorRole <<ValueObject>> {
    +Name: string
}

MediaWork "1" *-- "1..*" Contribution

' ===== CONTENT =====
class Content <<Entity>> {
    +Id: UUID
    +Title?: string
    +Description?: string
}

MediaWork "1" *-- "0..*" Content

class PlayableContent {
    +RuntimeMinutes: int
    +CutType?: CutType
    +SubtitleTracks: List<string>
}

enum CutType {
    DirectorCut
    Extended
    FinalCut
    HomeRelease
    International
    Original
    Other
    Theatrical
    Uncut
}

Content <|-- PlayableContent

class AudioTrack <<ValueObject>> {
    +Language: string
    +Format: string
}

PlayableContent "1" *-- "0..*" AudioTrack

' ===== MOVIE =====
class MovieStructure {
    -_features: List<UUID>
    --
    +AddFeature(id): void
    +RemoveFeature(id): void
}

MediaStructure <|-- MovieStructure
MovieStructure ..> PlayableContent

' ===== TV =====
class TVStructure {
    +Status: TVStatus
    +EndedOn?: LocalDate
    -_episodes: List<UUID>
    --
    +AddEpisode(id): void
    +RemoveEpisode(id): void
}

MediaStructure <|-- TVStructure
TVStructure ..> PlayableContent

enum TVStatus {
    Ongoing
    Ended
    Cancelled
    Unknown
}

class Season <<Entity>> {
    +Id: UUID
    +SeasonNumber: int
    +Title: string?
    +Description: string?
}

TVStructure "1" *-- "1..*" Season

class Episode {
    +episodeId: UUID
    +Title?: string
    +Description?: string
    +EpisodeNumber?: int
    +AirDate: LocalDate
}

Season "1" *-- "1..*" Episode
Episode ..> PlayableContent

@enduml
