@startuml
skinparam classAttributeIconSize 0

' ===== CORE =====
abstract class MediaWork <<AggregateRoot>> {
    +Id: UUID
    +Title: string
    +OriginalReleaseDate: LocalDate
    -_contributions: List<Contribution>
    #_creatorRoles: List<ContributorRole>
    --
    +AddContribution(id, role): void
    +RemoveContribution(id): void
    +AddEdition(id): void
    +RemoveEdition(id): void
    +IsCreatorRole(role): bool
}

note top of MediaWork
Invariant:
- Must have at least one Contribution
  where concrete MediaWork considers Role
  a creator (member of _creatorRoles)
- Cannot remove last creator
- Cannot remove Edition if MediaCopy
  exists referencing it (cross-aggregate
  constraint, enforce in application
  layer)
end note

abstract class Content <<Entity>> {
    +Id: UUID
    +Title?: string
}

MediaWork "1..*" *-- "0..*" Content

class BonusContent {
    RuntimeMinutes?: int
}

Content <|-- BonusContent

class Contribution <<Entity>> {
    +Id: UUID
    +ContributorId: UUID
    +Role: ContributorRole
}

class ContributorRole <<ValueObject>> {
    +Name: string
}

MediaWork "1" *-- "1..*" Contribution

' ===== MOVIE =====
class Movie {}

Movie --|> MediaWork

class MovieFeature {
    +RuntimeMinutes: int
    +CutType: MovieCutType
}

enum MovieCutType {
    Theatrical
    Extended
    DirectorCut
    FinalCut
    Other
}

Content <|-- MovieFeature

' ===== TV =====
class TV {
    +EndDate: LocalDate?
}

TV --|> MediaWork

class Season <<Entity>> {
    +Id: UUID
    +SeasonNumber: int
    +EpisodeIds: List<UUID>
    +Title: string?
}

class Episode {
    +EpisodeNumber: int
    +AirDate: LocalDate
    +RuntimeMinutes: int
}

Content <|-- Episode
Season ..> Episode

TV "1" *-- "1..*" Season

' ===== SHARED =====
class AudioTrack <<ValueObject>> {
    +Language: string
    +Format: string
}

MovieFeature "1" *-- "0..*" AudioTrack
Episode "1" *-- "0..*" AudioTrack
BonusContent "1" *-- "0..*" AudioTrack

@enduml
