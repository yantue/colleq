@startuml
skinparam classAttributeIconSize 0

class Edition <<AggregateRoot>> {
    +Id: UUID
    +Title: string
    +ReleaseDate: LocalDate
    +MediaWorks: List<UUID>
    +Packaging?: MediaPackaging
}

note top of Edition
Invariant:
- For each contentId in MediaCarrier.Content,
  there exists an EditionContent with that contentId
end note

class EditionContent {
    ContentId: UUID
    Role: ContentRole
}

Edition "1" *-- "1..*" EditionContent

enum ContentRole {
    Main
    Bonus
}

class MediaCarrier <<ValueObject>> {
    +Title?: string
    +Content: List<UUID>
}

Edition "1" *-- "1..*" MediaCarrier

class DiscCarrier {
    +Type: DiscType
    +RegionCodes?: List<RegionCode>
}

MediaCarrier <|-- DiscCarrier

enum MediaPackaging {
    Boxset
    Digipack
    Mediabook
    Slipcover
    Amaray
    Steelbook
}

enum DiscType {
    BluRay
    DVD
    UHD
}

enum RegionCode {
    A
    B
    C
    0ALL
    1
    2
    3
    4
    5
    6
    7
    8
}

@enduml
