@startuml
skinparam classAttributeIconSize 0

class Edition <<AggregateRoot>> {
    +Id: UUID
    +Title: string
    +ReleaseDate: LocalDate
    +MediaWorks: List<UUID>
    +Packaging?: MediaPackaging
}

note top of Edition
Invariant:
- For each contentId in MediaCarrier.Content,
  there exists an EditionContent with that contentId
  that references a content in MediaWork._contents
end note

class EditionContent <<ValueObject>> {
    +ContentId: UUID
    +Role: ContentRole
}

Edition "1" *-- "1..*" EditionContent

enum ContentRole {
    Primary
    Secondary
}

class MediaCarrier <<Entity>> {
    +Id: UUID
    +Title?: string
    +Content: List<UUID>
}

Edition "1" *-- "1..*" MediaCarrier

class DiscCarrier {
    +Type: DiscType
    +RegionCodes?: List<RegionCode>
}

MediaCarrier <|-- DiscCarrier

class DigitalCarrier {
    +Type: DigitalType
    +Platform?: string
}

MediaCarrier <|-- DigitalCarrier

enum MediaPackaging {
    Amaray
    Boxset
    Digipack
    Mediabook
    Slipcover
    Steelbook
}

enum DiscType {
    BluRay
    DVD
    UHD
}

enum DigitalType {
    Download
    Streaming
}

enum RegionCode {
    A
    B
    C
    0ALL
    1
    2
    3
    4
    5
    6
    7
    8
}

@enduml
