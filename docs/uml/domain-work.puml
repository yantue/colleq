@startuml
skinparam classAttributeIconSize 0

enum VideoMedium {
    DVD
    BluRay
    UHD
    Digital
}

enum VideoCase {
    Standard
    Steelbook
    Digipack
    Slipcover
    Boxset
    Mediabook
    Other
}

class CollectionGroup <<AggregateRoot>> {
    +Id: UUID
    +Title: string
}

class CollectionGroupMembership <<Entity>> {
    +MediaWorkId: UUID
    +SortIndex: int
}

abstract class MediaWork <<AggregateRoot>> {
    +Id: UUID
    +Title: string
    +OriginalReleaseDate: LocalDate
    -_contributions: List<Contribution>
    #_creatorRoles: List<string>
    --
    +AddContribution(id, role): void
    +RemoveContribution(id): void
    +AddEdition(id): void
    +RemoveEdition(id): void
    +IsCreatorRole(role): bool
}

class Movie
class TV {
    +EndDate: LocalDate?
}

class ExtraType <<ValueObject>> {
    +Name: string
}

class Extra <<ValueObject>> {
    +Description: string
    +Type: ExtraType
}

abstract class Edition <<Entity>> {
    +Id: UUID
    +ReleaseDate: LocalDate
    +Extras: List<Extra>
}

class MovieEdition {
    +RuntimeMinutes: int
    +Medium: VideoMedium
    +Case: VideoCase
    +DiscCount: int
    +AudioTracks: List<AudioTrack>
    +SubtitleTracks: List<string>
}

class Episode <<Entity>> {
    +Id: UUID
    +EpisodeNumber: int
    +AirDate: LocalDate
    +RuntimeMinutes: int
    +Title: string?
}

class Season <<Entity>> {
    +Id: UUID
    +SeasonNumber: int
    +Episode: List<Episode>
    +OriginalReleaseDate: LocalDate
    +Title: string?
}

Season "1" *-- "1..*" Episode

class TVEdition {
    +CoveredSeasonNumbers: List<int>
    +Medium: VideoMedium
    +Case: VideoCase
    +DiscCount: int
    +AudioTracks: List<AudioTrack>
    +SubtitleTracks: List<string>
}

class AudioTrack <<ValueObject>> {
    +Language: string
    +Format: string
}

CollectionGroup "1" *-- "0..*" CollectionGroupMembership

MediaWork <.. CollectionGroupMembership
MediaWork "1" *-- "0..*" Edition

Movie --|> MediaWork
TV --|> MediaWork

Edition <|-- MovieEdition
Edition <|-- TVEdition

TV "1" *-- "1..*" Season

class Contributor <<AggregateRoot>> {
    +Id: UUID
    +Name: string
}

class ContributorRole <<ValueObject>> {
    +Name: string
}

class Contribution <<Entity>> {
    +Id: UUID
    +ContributorId: UUID
    +Role: ContributorRole
}

MediaWork "1" *-- "1..*" Contribution
Contribution ..> Contributor

note top of MediaWork
Invariant:
- Must have at least one Contribution
  where concrete MediaWork considers Role
  a creator (member of _creatorRoles)
- Cannot remove last creator
- Cannot remove Edition if MediaCopy
  exists referencing it (cross-aggregate
  constraint, enforce in application
  layer)
end note

note top of TVEdition
Invariant:
- Must have at least one CoveredSeasonNumber
end note

note bottom of CollectionGroupMembership
Invariant:
- MediaWork can appear only once per
  CollectionGroup
- SortIndex defines the relative
  position of the MediaWork within the
  CollectionGroup, gaps allowed but no
  duplicates
end note

class Location <<ValueObject>> {
    +Name: string
}

class Note <<ValueObject>> {
    +Text: string
    +CreatedAt: LocalDate
}

class MediaCopy <<AggregateRoot>> {
    +Id: UUID
    +EditionId: UUID
    +Location: Location
    +Notes: List<Note>
}

MediaCopy ..> Edition

@enduml

